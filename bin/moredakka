#!/usr/bin/env python3

import argparse
import concurrent.futures
import json
import os
import re
import shlex
import shutil
import subprocess
import sys
import textwrap
import time
from dataclasses import dataclass
from datetime import datetime, timezone
from pathlib import Path
from typing import Dict, Iterable, List, Optional, Sequence, Tuple


READ_ONLY_TOOLS = "read,grep,find,ls"
ANSI_RE = re.compile(r"\x1b\[[0-9;]*[A-Za-z]")
LINE_LIMIT = 120
TEXT_LIMIT = 12000


ROLE_TEXT = {
    "gpt-plan": """
Principal planner. Build the strongest execution sequence for the task.
Bias toward concrete ordering, entry points, and what should happen first.
""",
    "gpt-risk": """
Adversarial planner. Attack the obvious plan. Find hidden assumptions,
failure modes, and the checks that need to happen before edits.
""",
    "gpt-prune": """
Scope-cutter. Remove waste, gold-plating, and detours. Keep the plan lean
without being sloppy.
""",
    "codex-recon": """
Repo scout. Inspect the tree like an engineer dropped into the codebase.
Identify the likely files, commands, and fast path through the task.
""",
    "gemini-counter": """
Counterpoint generator. Bring a different reasoning style. Stress-test
architecture and sequencing, especially where the initial approach may be
overfit to one model's habits.
""",
    "claude-sharpener": """
Clarity pass. Tighten the plan, call out ambiguity, and improve handoff
quality. Prefer concise, high-signal recommendations.
""",
    "kimi-outsider": """
Outsider perspective. Look for non-obvious shortcuts, blind spots, or a
better framing than the default implementation path.
""",
    "grok-wildcard": """
Wildcard reviewer. Offer one or two aggressive alternatives, but only if
they materially reduce time or risk.
""",
    "gpt-synth": """
Final synthesizer. Merge the competing memos into one executable plan.
Resolve disagreement instead of averaging it away.
""",
}


PROFILE_RUNNERS = {
    "fast": ["gpt-plan", "gpt-risk", "codex-recon", "gemini-counter"],
    "default": [
        "gpt-plan",
        "gpt-risk",
        "gpt-prune",
        "codex-recon",
        "gemini-counter",
        "claude-sharpener",
        "kimi-outsider",
    ],
    "heavy": [
        "gpt-plan",
        "gpt-risk",
        "gpt-prune",
        "codex-recon",
        "gemini-counter",
        "claude-sharpener",
        "kimi-outsider",
        "grok-wildcard",
    ],
}


@dataclass(frozen=True)
class RunnerSpec:
    name: str
    adapter: str
    model: str
    provider: Optional[str] = None
    thinking: str = "xhigh"
    required_env: Tuple[str, ...] = ()


@dataclass
class RunRecord:
    name: str
    adapter: str
    model: str
    status: str
    stdout: str
    stderr: str
    seconds: float
    command: List[str]
    note: str = ""


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        prog="moredakka",
        description=(
            "Throw a multi-model planning swarm at the current task, then "
            "synthesize an executable plan of operations."
        ),
    )
    parser.add_argument(
        "objective",
        nargs="*",
        help="Task objective. If omitted, moredakka reads it from stdin.",
    )
    parser.add_argument(
        "--profile",
        choices=sorted(PROFILE_RUNNERS.keys()),
        default="default",
        help="Fanout size. Default: %(default)s",
    )
    parser.add_argument(
        "--iterations",
        type=int,
        default=2,
        help=(
            "Number of synthesis passes. 1 = fanout + synth. "
            "2 = fanout + synth + critique + final synth. Default: %(default)s"
        ),
    )
    parser.add_argument(
        "--focus",
        action="append",
        default=[],
        help="Path to prioritize in the prompt. Repeatable.",
    )
    parser.add_argument(
        "--cwd",
        default=".",
        help="Working directory the model swarm should inspect. Default: current directory.",
    )
    parser.add_argument(
        "--out",
        default="",
        help="Output directory for artifacts. Default: .moredakka/runs/<timestamp>",
    )
    parser.add_argument(
        "--only",
        default="",
        help="Comma-separated runner names to use instead of a profile.",
    )
    parser.add_argument(
        "--max-parallel",
        type=int,
        default=4,
        help="Maximum concurrent fanout calls. Default: %(default)s",
    )
    parser.add_argument(
        "--timeout",
        type=int,
        default=1200,
        help="Per-model timeout in seconds. Default: %(default)s",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Print the planned commands and save context, but do not call models.",
    )
    parser.add_argument(
        "--json",
        action="store_true",
        help="Emit a machine-readable JSON summary to stdout.",
    )
    args = parser.parse_args()
    if args.iterations < 1:
        parser.error("--iterations must be at least 1")
    if args.max_parallel < 1:
        parser.error("--max-parallel must be at least 1")
    if args.timeout < 1:
        parser.error("--timeout must be at least 1")
    return args


def read_objective(args: argparse.Namespace) -> str:
    if args.objective:
        return " ".join(args.objective).strip()
    if not sys.stdin.isatty():
        return sys.stdin.read().strip()
    raise SystemExit("moredakka needs an objective string or stdin input.")


def load_shell_env(files: Iterable[Path]) -> Dict[str, str]:
    env = dict(os.environ)
    for file_path in files:
        if not file_path or not file_path.is_file():
            continue
        for raw_line in file_path.read_text(encoding="utf-8", errors="ignore").splitlines():
            line = raw_line.strip()
            if not line or line.startswith("#"):
                continue
            if line.startswith("export "):
                line = line[7:].strip()
            if "=" not in line:
                continue
            key, value = line.split("=", 1)
            key = key.strip()
            value = value.strip()
            if value and value[0] == value[-1] and value[0] in ("'", '"'):
                value = value[1:-1]
            env.setdefault(key, value)
    return env


def repo_root_for(cwd: Path) -> Optional[Path]:
    try:
        proc = subprocess.run(
            ["git", "-C", str(cwd), "rev-parse", "--show-toplevel"],
            capture_output=True,
            text=True,
            check=True,
        )
    except (OSError, subprocess.CalledProcessError):
        return None
    return Path(proc.stdout.strip()) if proc.stdout.strip() else None


def run_capture(
    command: Sequence[str],
    *,
    cwd: Path,
    env: Dict[str, str],
    timeout: int = 20,
) -> Tuple[int, str, str]:
    try:
        proc = subprocess.run(
            list(command),
            cwd=str(cwd),
            env=env,
            capture_output=True,
            text=True,
            timeout=timeout,
            check=False,
        )
    except FileNotFoundError as exc:
        return 127, "", str(exc)
    except subprocess.TimeoutExpired as exc:
        stdout = exc.stdout or ""
        stderr = exc.stderr or ""
        return 124, stdout, stderr or f"Timed out after {timeout}s"
    return proc.returncode, proc.stdout, proc.stderr


def trim_lines(text: str, limit: int = LINE_LIMIT) -> str:
    lines = text.strip().splitlines()
    if len(lines) <= limit:
        return "\n".join(lines)
    kept = lines[:limit]
    kept.append(f"... ({len(lines) - limit} more lines truncated)")
    return "\n".join(kept)


def trim_text(text: str, limit: int = TEXT_LIMIT) -> str:
    text = sanitize_text(text)
    if len(text) <= limit:
        return text
    return text[:limit].rstrip() + "\n\n... [truncated]"


def sanitize_text(text: str) -> str:
    return ANSI_RE.sub("", text or "").replace("\x00", "")


def discover_context_docs(cwd: Path, repo_root: Optional[Path]) -> List[Path]:
    docs: List[Path] = []
    names = ("AGENTS.md", "CLAUDE.md", "README.md")
    ceiling = repo_root or cwd
    current = cwd
    visited = set()
    while True:
        if current in visited:
            break
        visited.add(current)
        for name in names:
            candidate = current / name
            if candidate.is_file():
                docs.append(candidate)
        if current == ceiling or current.parent == current:
            break
        current = current.parent
    unique: List[Path] = []
    seen = set()
    for doc in docs:
        if doc in seen:
            continue
        seen.add(doc)
        unique.append(doc)
    return unique


def relativize(path: Path, base: Optional[Path]) -> str:
    if base is None:
        return str(path)
    try:
        return str(path.relative_to(base))
    except ValueError:
        return str(path)


def gather_workspace_snapshot(cwd: Path, repo_root: Optional[Path], env: Dict[str, str], focus: List[Path]) -> str:
    sections: List[str] = []
    sections.append(f"- cwd: {cwd}")
    sections.append(f"- repo_root: {repo_root or cwd}")
    if repo_root:
        code, branch, _ = run_capture(
            ["git", "-C", str(cwd), "branch", "--show-current"],
            cwd=cwd,
            env=env,
            timeout=10,
        )
        if code == 0 and branch.strip():
            sections.append(f"- branch: {branch.strip()}")
        code, status, _ = run_capture(
            ["git", "-C", str(cwd), "status", "--short", "--branch"],
            cwd=cwd,
            env=env,
            timeout=10,
        )
        if code == 0 and status.strip():
            sections.append("\nGit status:\n" + trim_lines(status))
        code, diff_stat, _ = run_capture(
            ["git", "-C", str(cwd), "diff", "--stat"],
            cwd=cwd,
            env=env,
            timeout=10,
        )
        if code == 0 and diff_stat.strip():
            sections.append("\nGit diff --stat:\n" + trim_lines(diff_stat))
        code, staged_stat, _ = run_capture(
            ["git", "-C", str(cwd), "diff", "--cached", "--stat"],
            cwd=cwd,
            env=env,
            timeout=10,
        )
        if code == 0 and staged_stat.strip():
            sections.append("\nGit diff --cached --stat:\n" + trim_lines(staged_stat))
    if focus:
        focus_lines = [f"- {relativize(path, repo_root)}" for path in focus]
        sections.append("\nFocus paths:\n" + "\n".join(focus_lines))
    docs = discover_context_docs(cwd, repo_root)
    if docs:
        doc_lines = [f"- {relativize(path, repo_root)}" for path in docs]
        sections.append("\nContext docs:\n" + "\n".join(doc_lines))
    if not repo_root:
        code, listing, _ = run_capture(
            ["find", ".", "-maxdepth", "2", "-type", "f"],
            cwd=cwd,
            env=env,
            timeout=10,
        )
        if code == 0 and listing.strip():
            sections.append("\nNearby files:\n" + trim_lines(listing))
    return "\n".join(sections).strip()


def build_runner_specs(env: Dict[str, str]) -> Dict[str, RunnerSpec]:
    def env_or_default(name: str, default: str) -> str:
        return env.get(name, default)

    openai_env = ("OPENAI_API_KEY",)
    gemini_env = ("GEMINI_API_KEY",)
    openrouter_env = ("OPENROUTER_API_KEY",)
    return {
        "gpt-plan": RunnerSpec(
            "gpt-plan",
            "pi",
            env_or_default("MOREDAKKA_OPENAI_MODEL", "gpt-5.4-pro"),
            provider="openai",
            required_env=openai_env,
        ),
        "gpt-risk": RunnerSpec(
            "gpt-risk",
            "pi",
            env_or_default("MOREDAKKA_OPENAI_MODEL", "gpt-5.4-pro"),
            provider="openai",
            required_env=openai_env,
        ),
        "gpt-prune": RunnerSpec(
            "gpt-prune",
            "pi",
            env_or_default("MOREDAKKA_OPENAI_MODEL", "gpt-5.4-pro"),
            provider="openai",
            required_env=openai_env,
        ),
        "codex-recon": RunnerSpec(
            "codex-recon",
            "codex",
            env_or_default("MOREDAKKA_CODEX_MODEL", "gpt-5.4-codex"),
        ),
        "gemini-counter": RunnerSpec(
            "gemini-counter",
            "pi",
            env_or_default("MOREDAKKA_GEMINI_MODEL", "gemini-3.1-pro-preview"),
            provider="google",
            required_env=gemini_env,
        ),
        "claude-sharpener": RunnerSpec(
            "claude-sharpener",
            "pi",
            env_or_default("MOREDAKKA_CLAUDE_MODEL", "anthropic/claude-sonnet-4.6"),
            required_env=openrouter_env,
        ),
        "kimi-outsider": RunnerSpec(
            "kimi-outsider",
            "pi",
            env_or_default("MOREDAKKA_KIMI_MODEL", "moonshotai/kimi-k2.5"),
            required_env=openrouter_env,
        ),
        "grok-wildcard": RunnerSpec(
            "grok-wildcard",
            "pi",
            env_or_default("MOREDAKKA_GROK_MODEL", "x-ai/grok-4"),
            required_env=openrouter_env,
        ),
        "gpt-synth": RunnerSpec(
            "gpt-synth",
            "pi",
            env_or_default("MOREDAKKA_OPENAI_MODEL", "gpt-5.4-pro"),
            provider="openai",
            required_env=openai_env,
        ),
    }


def build_common_prompt(objective: str, snapshot: str, role_key: str) -> str:
    role_text = textwrap.dedent(ROLE_TEXT[role_key]).strip()
    return textwrap.dedent(
        f"""
        You are one worker in a multi-model planning swarm. Your job is to improve
        the plan of operations for the current coding task, not to implement it.

        Role:
        {role_text}

        Hard rules:
        - Inspect the repository directly before you conclude.
        - Work from the workspace snapshot below, but verify repo facts with tools.
        - Prefer concrete file paths, sequencing, validation steps, and shortcuts.
        - Keep the response terse and operational.
        - Do not waste time on style commentary or generic best-practice filler.

        Task objective:
        {objective}

        Workspace snapshot:
        {snapshot}

        Return markdown with exactly these sections:
        ## Objective
        ## Recommended Plan
        ## Immediate Actions
        ## Risks
        ## Don't Waste Time On
        """
    ).strip()


def build_synthesis_prompt(
    objective: str,
    snapshot: str,
    memos: Sequence[RunRecord],
    prior_plan: str,
    iteration: int,
) -> str:
    memo_blocks = []
    for memo in memos:
        if memo.status != "ok":
            continue
        memo_blocks.append(
            f"### {memo.name} ({memo.model})\n{trim_text(memo.stdout)}"
        )
    memo_text = "\n\n".join(memo_blocks) or "No successful memos."
    previous = trim_text(prior_plan) if prior_plan else "None yet."
    return textwrap.dedent(
        f"""
        You are the final planner in a multi-model swarm. Merge the model memos
        into one executable plan of operations for the task below.

        Task objective:
        {objective}

        Workspace snapshot:
        {snapshot}

        Previous synthesized plan:
        {previous}

        Model memos:
        {memo_text}

        This is synthesis pass {iteration}.

        Requirements:
        - Resolve disagreement explicitly. Do not just average conflicting advice.
        - Prefer the simplest plan that matches the repository reality.
        - Keep it concrete, terse, and directly executable.
        - If a proposed step depends on an unknown, say how to verify it first.

        Return markdown with exactly these sections:
        ## Final Plan
        ## Next Commands
        ## Key Risks
        ## Decision Notes
        """
    ).strip()


def build_critique_prompt(objective: str, snapshot: str, draft_plan: str) -> str:
    return textwrap.dedent(
        f"""
        Critique the draft plan harshly. Your job is to break it, not to be polite.

        Task objective:
        {objective}

        Workspace snapshot:
        {snapshot}

        Draft plan:
        {trim_text(draft_plan)}

        Find:
        - missing repo checks
        - dangerous assumptions
        - wasted work
        - sequencing mistakes
        - simpler alternatives

        Return markdown with exactly these sections:
        ## Breakpoints
        ## Fixes
        ## Better Ordering
        """
    ).strip()


def build_command(spec: RunnerSpec, prompt: str, cwd: Path, repo_root: Optional[Path]) -> List[str]:
    if spec.adapter == "pi":
        command = ["pi"]
        if spec.provider and "/" not in spec.model:
            command.extend(["--provider", spec.provider])
        command.extend(
            [
                "--model",
                spec.model,
                "--tools",
                READ_ONLY_TOOLS,
                "--thinking",
                spec.thinking,
                "--no-session",
                "-p",
                prompt,
            ]
        )
        return command
    if spec.adapter == "codex":
        command = [
            "codex",
            "exec",
            "-s",
            "read-only",
            "-m",
            spec.model,
            "-c",
            'model_reasoning_effort="xhigh"',
            "--ephemeral",
            "-C",
            str(cwd),
        ]
        if repo_root is None:
            command.append("--skip-git-repo-check")
        command.append(prompt)
        return command
    raise ValueError(f"Unknown adapter: {spec.adapter}")


def ensure_output_dir(path_arg: str, cwd: Path) -> Path:
    if path_arg:
        out_dir = Path(path_arg).expanduser().resolve()
    else:
        stamp = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")
        out_dir = (cwd / ".moredakka" / "runs" / stamp).resolve()
    out_dir.mkdir(parents=True, exist_ok=True)
    return out_dir


def write_text(path: Path, text: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(text, encoding="utf-8")


def slug(name: str) -> str:
    return re.sub(r"[^a-zA-Z0-9._-]+", "-", name).strip("-").lower() or "artifact"


def run_runner(
    spec: RunnerSpec,
    *,
    prompt: str,
    cwd: Path,
    repo_root: Optional[Path],
    env: Dict[str, str],
    dry_run: bool,
    timeout: int = 3600,
) -> RunRecord:
    command = build_command(spec, prompt, cwd, repo_root)
    missing_vars = [key for key in spec.required_env if not env.get(key)]
    binary = shutil.which(command[0])
    if missing_vars:
        return RunRecord(
            name=spec.name,
            adapter=spec.adapter,
            model=spec.model,
            status="skipped",
            stdout="",
            stderr="",
            seconds=0.0,
            command=command,
            note="missing env: " + ", ".join(missing_vars),
        )
    if binary is None:
        return RunRecord(
            name=spec.name,
            adapter=spec.adapter,
            model=spec.model,
            status="skipped",
            stdout="",
            stderr="",
            seconds=0.0,
            command=command,
            note=f"missing binary: {command[0]}",
        )
    if dry_run:
        return RunRecord(
            name=spec.name,
            adapter=spec.adapter,
            model=spec.model,
            status="dry-run",
            stdout="",
            stderr="",
            seconds=0.0,
            command=command,
            note="command not executed",
        )
    started = time.time()
    code, stdout, stderr = run_capture(command, cwd=cwd, env=env, timeout=timeout)
    status = "ok" if code == 0 else "error"
    return RunRecord(
        name=spec.name,
        adapter=spec.adapter,
        model=spec.model,
        status=status,
        stdout=sanitize_text(stdout).strip(),
        stderr=sanitize_text(stderr).strip(),
        seconds=time.time() - started,
        command=command,
        note=f"exit={code}",
    )


def choose_fanout(specs: Dict[str, RunnerSpec], args: argparse.Namespace) -> List[RunnerSpec]:
    if args.only:
        names = [name.strip() for name in args.only.split(",") if name.strip()]
    else:
        names = PROFILE_RUNNERS[args.profile]
    missing = [name for name in names if name not in specs]
    if missing:
        raise SystemExit(f"Unknown runner names: {', '.join(missing)}")
    return [specs[name] for name in names]


def choose_critique_runner(
    specs: Dict[str, RunnerSpec],
    env: Dict[str, str],
    used_names: Sequence[str],
) -> RunnerSpec:
    preferred = [
        "gemini-counter",
        "claude-sharpener",
        "grok-wildcard",
        "kimi-outsider",
        "codex-recon",
    ]
    available = set(used_names) | set(specs.keys())
    for name in preferred:
        if name not in available:
            continue
        spec = specs[name]
        binary = "codex" if spec.adapter == "codex" else "pi"
        if shutil.which(binary) is None:
            continue
        if any(not env.get(key) for key in spec.required_env):
            continue
        return spec
    return specs["codex-recon"]


def preview_command(command: Sequence[str]) -> str:
    preview: List[str] = []
    for index, part in enumerate(command):
        if index == len(command) - 1 and len(part) > 300:
            preview.append(part[:300].rstrip() + "... [prompt truncated]")
        else:
            preview.append(part)
    return shlex.join(preview)


def record_to_dict(record: RunRecord) -> Dict[str, object]:
    return {
        "name": record.name,
        "adapter": record.adapter,
        "model": record.model,
        "status": record.status,
        "seconds": round(record.seconds, 2),
        "note": record.note,
        "command_preview": preview_command(record.command),
        "stderr": trim_text(record.stderr, 4000),
    }


def render_summary(
    *,
    objective: str,
    out_dir: Path,
    fanout: Sequence[RunRecord],
    synths: Sequence[RunRecord],
    critiques: Sequence[RunRecord],
    final_plan: str,
) -> str:
    lines = [
        "# moredakka",
        "",
        f"Objective: {objective}",
        f"Artifacts: {out_dir}",
        "",
        "## Runners",
    ]
    for record in list(fanout) + list(critiques) + list(synths):
        status = record.status
        detail = record.note
        seconds = f"{record.seconds:.1f}s" if record.seconds else "0.0s"
        lines.append(f"- {record.name}: {status} ({record.model}, {seconds}) {detail}".rstrip())
    lines.extend(["", "## Final Plan", final_plan.strip() or "_No final plan generated._"])
    return "\n".join(lines).strip() + "\n"


def main() -> int:
    args = parse_args()
    objective = read_objective(args)
    cwd = Path(args.cwd).expanduser().resolve()
    if not cwd.exists():
        raise SystemExit(f"Working directory does not exist: {cwd}")
    repo_root = repo_root_for(cwd)
    env = load_shell_env(
        [
            Path.home() / ".codex" / "secrets.env",
            (repo_root or cwd) / ".env",
            cwd / ".env",
        ]
    )
    specs = build_runner_specs(env)
    focus_paths = [(cwd / entry).resolve() for entry in args.focus]
    out_dir = ensure_output_dir(args.out, cwd)
    snapshot = gather_workspace_snapshot(cwd, repo_root, env, focus_paths)
    write_text(out_dir / "context.md", snapshot + "\n")
    fanout_specs = choose_fanout(specs, args)

    fanout_results: List[RunRecord] = []
    with concurrent.futures.ThreadPoolExecutor(max_workers=min(args.max_parallel, len(fanout_specs))) as pool:
        future_map = {}
        for spec in fanout_specs:
            prompt = build_common_prompt(objective, snapshot, spec.name)
            write_text(out_dir / f"prompt-{slug(spec.name)}.md", prompt + "\n")
            future = pool.submit(
                run_runner,
                spec,
                prompt=prompt,
                cwd=cwd,
                repo_root=repo_root,
                env=env,
                dry_run=args.dry_run,
                timeout=args.timeout,
            )
            future_map[future] = spec
        for future in concurrent.futures.as_completed(future_map):
            result = future.result()
            fanout_results.append(result)
            artifact = {
                "meta": record_to_dict(result),
                "stdout": result.stdout,
                "stderr": result.stderr,
            }
            write_text(
                out_dir / f"{slug(result.name)}.json",
                json.dumps(artifact, indent=2) + "\n",
            )

    fanout_results.sort(key=lambda item: item.name)
    successful_fanout = [result for result in fanout_results if result.status == "ok"]
    synth_results: List[RunRecord] = []
    critique_results: List[RunRecord] = []
    final_plan = ""

    if args.dry_run:
        summary = {
            "objective": objective,
            "out_dir": str(out_dir),
            "fanout": [record_to_dict(item) for item in fanout_results],
            "synthesizers": [],
            "final_plan": "",
        }
        write_text(out_dir / "summary.json", json.dumps(summary, indent=2) + "\n")
        if args.json:
            print(json.dumps(summary, indent=2))
        else:
            for item in fanout_results:
                print(f"[dry-run] {item.name}: {preview_command(item.command)}")
            print(f"\nArtifacts: {out_dir}")
        return 0

    if not successful_fanout:
        summary = {
            "objective": objective,
            "out_dir": str(out_dir),
            "fanout": [record_to_dict(item) for item in fanout_results],
            "error": "No fanout runner completed successfully.",
        }
        write_text(out_dir / "summary.json", json.dumps(summary, indent=2) + "\n")
        if args.json:
            print(json.dumps(summary, indent=2))
        else:
            print(render_summary(
                objective=objective,
                out_dir=out_dir,
                fanout=fanout_results,
                synths=[],
                critiques=[],
                final_plan="No final plan generated.",
            ))
        return 2

    current_plan = ""
    critique_runner = choose_critique_runner(specs, env, [spec.name for spec in fanout_specs])
    for index in range(1, args.iterations + 1):
        synth_prompt = build_synthesis_prompt(objective, snapshot, successful_fanout + critique_results, current_plan, index)
        write_text(out_dir / f"prompt-synth-{index}.md", synth_prompt + "\n")
        synth_result = run_runner(
            specs["gpt-synth"],
            prompt=synth_prompt,
            cwd=cwd,
            repo_root=repo_root,
            env=env,
            dry_run=False,
            timeout=args.timeout,
        )
        synth_results.append(synth_result)
        write_text(
            out_dir / f"synth-{index}.json",
            json.dumps(
                {
                    "meta": record_to_dict(synth_result),
                    "stdout": synth_result.stdout,
                    "stderr": synth_result.stderr,
                },
                indent=2,
            ) + "\n",
        )
        current_plan = synth_result.stdout or current_plan
        if not current_plan.strip():
            break
        if index == args.iterations:
            break
        critique_prompt = build_critique_prompt(objective, snapshot, current_plan)
        write_text(out_dir / f"prompt-critique-{index}.md", critique_prompt + "\n")
        critique_result = run_runner(
            critique_runner,
            prompt=critique_prompt,
            cwd=cwd,
            repo_root=repo_root,
            env=env,
            dry_run=False,
            timeout=args.timeout,
        )
        critique_results.append(critique_result)
        write_text(
            out_dir / f"critique-{index}.json",
            json.dumps(
                {
                    "meta": record_to_dict(critique_result),
                    "stdout": critique_result.stdout,
                    "stderr": critique_result.stderr,
                },
                indent=2,
            ) + "\n",
        )

    final_plan = current_plan.strip()
    write_text(out_dir / "final-plan.md", final_plan + "\n")
    summary = {
        "objective": objective,
        "out_dir": str(out_dir),
        "fanout": [record_to_dict(item) for item in fanout_results],
        "critiques": [record_to_dict(item) for item in critique_results],
        "synthesizers": [record_to_dict(item) for item in synth_results],
        "final_plan_file": str(out_dir / "final-plan.md"),
    }
    write_text(out_dir / "summary.json", json.dumps(summary, indent=2) + "\n")
    if args.json:
        payload = dict(summary)
        payload["final_plan"] = final_plan
        print(json.dumps(payload, indent=2))
    else:
        print(
            render_summary(
                objective=objective,
                out_dir=out_dir,
                fanout=fanout_results,
                synths=synth_results,
                critiques=critique_results,
                final_plan=final_plan,
            )
        )
    return 0


if __name__ == "__main__":
    sys.exit(main())
