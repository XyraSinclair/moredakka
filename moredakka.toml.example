[defaults]
mode = "plan"
max_rounds = 2
base_ref = "main"
char_budget = 24000
cache_dir = ".moredakka/cache"
run_dir = ".moredakka/runs"
novelty_threshold = 0.15
# max_total_tokens = 120000
# max_cost_usd = 2.50
# max_wall_seconds = 120

# Canonical default: one OpenRouter-backed roster with real contrast across roles.
# All providers below share the same OPENROUTER_API_KEY but use different model families.

[providers.openrouter_planner]
kind = "openrouter"
model = "anthropic/claude-opus-4.6"
api_key_env = "OPENROUTER_API_KEY"
base_url = "https://openrouter.ai/api/v1"
app_name = "moredakka"
# input_cost_per_million_tokens = 15.00
# output_cost_per_million_tokens = 75.00

[providers.openrouter_implementer]
kind = "openrouter"
model = "openai/gpt-5.4"
api_key_env = "OPENROUTER_API_KEY"
reasoning_effort = "medium"
base_url = "https://openrouter.ai/api/v1"
app_name = "moredakka"

[providers.openrouter_breaker]
kind = "openrouter"
model = "google/gemini-3.1-pro-preview"
api_key_env = "OPENROUTER_API_KEY"
base_url = "https://openrouter.ai/api/v1"
app_name = "moredakka"

[providers.openrouter_minimalist]
kind = "openrouter"
model = "openai/gpt-5.4-mini"
api_key_env = "OPENROUTER_API_KEY"
reasoning_effort = "medium"
base_url = "https://openrouter.ai/api/v1"
app_name = "moredakka"

[providers.openrouter_synthesizer]
kind = "openrouter"
model = "openai/gpt-5.4"
api_key_env = "OPENROUTER_API_KEY"
reasoning_effort = "medium"
base_url = "https://openrouter.ai/api/v1"
app_name = "moredakka"

[roles.planner]
provider = "openrouter_planner"

[roles.implementer]
provider = "openrouter_implementer"

[roles.breaker]
provider = "openrouter_breaker"

[roles.minimalist]
provider = "openrouter_minimalist"

[roles.synthesizer]
provider = "openrouter_synthesizer"
